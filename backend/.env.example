# Copy to .env and fill in real values

# PostgreSQL connection string
# Local dev:  postgresql://postgres:postgres@localhost:5432/tranchi
# EC2 prod:   postgresql://tranchi_user:PASSWORD@localhost:5432/tranchi
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tranchi

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=<generate: openssl rand -hex 64>

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true during local development to enable Swagger UI
DEBUG=true

# Local dev user bypass (skips CF Zero Trust check)
DEV_USER_EMAIL=your@email.com

# Google Maps Street View Static API key — powers property thumbnails/hero images.
# Restrict the key to the Street View Static API + the tranchi hostname referrer.
# Leave blank to disable images (UI falls back to a placeholder).
GOOGLE_MAPS_API_KEY=

# ── Scraper overrides (optional) ────────────────────────────────────────────
# Hard cap on probate-court IDs explored per run. Leave blank to use the
# scraper's internal default (_DEFAULT_MAX_IDS in app/scrapers/probate.py).
PROBATE_MAX_IDS=
# "1" enables the Sheriff scraper's historical backfill sweep; "0" = normal mode.
SHERIFF_BACKFILL=0
