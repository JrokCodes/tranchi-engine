# Copy to .env and fill in real values

# PostgreSQL connection string
# Local dev:  postgresql://postgres:postgres@localhost:5432/tranchi
# EC2 prod:   postgresql://tranchi_user:PASSWORD@localhost:5432/tranchi
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tranchi

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=<generate: openssl rand -hex 64>

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true during local development to enable Swagger UI
DEBUG=true

# Local dev user bypass (skips CF Zero Trust check)
DEV_USER_EMAIL=your@email.com
